<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Quai Antique{% endblock %}</title>

    {# CSS global du site #}
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">

    {# Bloc CSS spécifique à chaque page #}
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# =================== HEADER =================== #}
    <header class="site-header">
        <a href="{{ path('app_accueil') }}" class="titre-logo">Quai Antique</a>

        <nav class="nav">
            <a class="nav-link" href="{{ path('app_accueil') }}">Accueil</a>
            <a class="nav-link" href="{{ path('app_carte') }}">Carte</a>
            <a class="nav-link" href="#">Galerie</a>
            <a class="nav-link" href="#">Réservation</a>
            <a class="nav-link" href="#">Connexion</a>
        </nav>
    </header>

    {# =================== MAIN =================== #}
    <main>
        {% block content %}{% endblock %}
    </main>

    {# =================== FOOTER =================== #}
    <footer class="site-footer">
        <div class="footer-links">
            <a href="#">À propos</a>
            <a href="#">Contact</a>
            <a href="#">Politique de confidentialité</a>
        </div>
        <p>© Quai Antique - Tous droits réservés</p>
        <p>1 rue de la cuisine, Chambéry</p>
    </footer>
</body>
</html>